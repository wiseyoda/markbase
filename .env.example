# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → New OAuth App
# Homepage URL: http://localhost:3000 (or your Vercel URL)
# Callback URL: http://localhost:3000/api/auth/callback/github (or your Vercel URL)
GITHUB_ID=
GITHUB_SECRET=

# Optional: GitHub webhook secret for immediate cache invalidation on push
# Configure the webhook URL as: https://your-domain/api/github/webhook
GITHUB_WEBHOOK_SECRET=

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Vercel Postgres (Neon) — added automatically by Vercel
POSTGRES_URL=

# Share link encryption — generate with: openssl rand -hex 32
SHARE_ENCRYPTION_KEY=
