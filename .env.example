# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → New OAuth App
# Homepage URL: http://localhost:3000 (or your Vercel URL)
# Callback URL: http://localhost:3000/api/auth/callback/github (or your Vercel URL)
GITHUB_ID=
GITHUB_SECRET=

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=
